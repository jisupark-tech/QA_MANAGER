# ============================================================
# Environment Variables Template
# ============================================================
# 복사: cp templates/env_template.env ../../.env
# 주의: .env 파일은 절대 Git에 커밋하지 마세요!
# .gitignore에 .env 가 포함되어 있는지 확인하세요
# ============================================================

# =====================
# LLM (필수)
# =====================
ANTHROPIC_API_KEY=sk-ant-xxxxx
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=4096
# LLM_TEMPERATURE=0.3

# =====================
# Vector DB - ChromaDB
# =====================
CHROMA_PERSIST_DIR=./data/chroma
# CHROMA_HOST=localhost         # Docker 사용 시
# CHROMA_PORT=8000

# =====================
# Redis (모듈 간 통신)
# =====================
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=                # 비밀번호 설정 시

# =====================
# Discord Bot (Phase 1)
# =====================
DISCORD_BOT_TOKEN=xxxxx
# 발급: https://discord.com/developers/applications

# =====================
# KakaoTalk (선택)
# =====================
# KAKAO_REST_API_KEY=xxxxx
# KAKAO_CHANNEL_ID=xxxxx

# =====================
# Game Database (게임별)
# =====================
# 게임명_DB_HOST / _PORT / _USER / _PASS / _NAME 형식
# 여러 게임이면 게임별로 접두사 변경

# 예시: CarMatch
# CARMATCH_DB_HOST=localhost
# CARMATCH_DB_PORT=3306
# CARMATCH_DB_USER=readonly_user
# CARMATCH_DB_PASS=xxxxx
# CARMATCH_DB_NAME=carmatch_db

# 예시: MyIdleGame
# MYIDLEGAME_DB_HOST=localhost
# MYIDLEGAME_DB_PORT=3306
# MYIDLEGAME_DB_USER=readonly_user
# MYIDLEGAME_DB_PASS=xxxxx
# MYIDLEGAME_DB_NAME=idle_db

# =====================
# Firebase (선택 - Phase 4)
# =====================
# FIREBASE_PROJECT_ID=my-project
# FIREBASE_CREDENTIALS_PATH=./secrets/firebase-key.json

# =====================
# Amplitude (선택 - Phase 4)
# =====================
# AMPLITUDE_API_KEY=xxxxx
# AMPLITUDE_SECRET_KEY=xxxxx

# =====================
# Google Play (선택 - Phase 2)
# =====================
# GOOGLE_PLAY_CREDENTIALS_PATH=./secrets/play-store-key.json

# =====================
# Admin Portal (Phase 5)
# =====================
ADMIN_SECRET_KEY=change-this-to-random-string
ADMIN_PORT=8080
# ADMIN_ALLOWED_ORIGINS=http://localhost:3000

# =====================
# Google OAuth (선택 - Phase 5)
# =====================
# GOOGLE_OAUTH_CLIENT_ID=xxxxx
# GOOGLE_OAUTH_CLIENT_SECRET=xxxxx
